# Copy this file to .env and fill in all values before starting the server.
# NEVER commit .env to git.

# Google OAuth 2.0 — from Google Cloud Console
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Session — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Business Central 14 on-prem
BC_BASE_URL=https://ej.hobrothers.com:9048/JW140PBIdev/ODataV4/Company('HOBrothers')
BC_USERNAME=hosrv\shaligram
BC_PASSWORD=

# Access control — only emails ending with this domain can log in
ALLOWED_DOMAIN=hobrothers.com

# OData page names — look these up in BC14: Administration > IT Administration > General > Web Services
BC_PAGE_JOBS=EJWJobs
BC_PAGE_JOBS_RW=EJWJobsRW
BC_PAGE_BOM=EJWJobComponents
BC_PAGE_IMAGES=JobImagesFactboxWS

# Server port (3005 for local dev, 443 for production HTTPS)
PORT=3005

# Set to 'true' in production to enable HTTPS (requires CERT_KEY_PATH and CERT_CERT_PATH)
USE_HTTPS=false
CERT_KEY_PATH=C:/certs/cadportal/privkey.pem
CERT_CERT_PATH=C:/certs/cadportal/fullchain.pem

# App URL — used for OAuth redirect URI
APP_URL=http://localhost:3005
